{
	"info": {
		"_postman_id": "oid4vp-collection-v1",
		"name": "OID4VP Authenticator - WSO2 IS",
		"description": "Postman collection for testing the OpenID4VP authenticator endpoints in WSO2 Identity Server.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "https://localhost:9443",
			"type": "string"
		},
		{
			"key": "admin_auth",
			"value": "Basic YWRtaW46YWRtaW4=",
			"type": "string"
		},
		{
			"key": "request_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "presentation_definition_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Presentation Definitions",
			"description": "CRUD operations for Presentation Definitions",
			"item": [
				{
					"name": "Create Presentation Definition (SD-JWT)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.id) {",
									"    pm.collectionVariables.set('presentation_definition_id', jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "{{admin_auth}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"University Credential\",\n  \"purpose\": \"Verify your university credential\",\n  \"definition\": {\n    \"id\": \"university-credential-def\",\n    \"name\": \"University Credential Verification\",\n    \"purpose\": \"Verify your university credential\",\n    \"input_descriptors\": [\n      {\n        \"id\": \"university-credential\",\n        \"name\": \"University Credential\",\n        \"purpose\": \"We need to verify your university credential\",\n        \"format\": {\n          \"vc+sd-jwt\": {}\n        },\n        \"constraints\": {\n          \"fields\": [\n            {\n              \"path\": [\"$.vct\"],\n              \"filter\": {\n                \"type\": \"string\",\n                \"const\": \"UniversityDegreeCredential\"\n              }\n            },\n            {\n              \"path\": [\"$.email\"]\n            }\n          ]\n        }\n      }\n    ]\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/presentation-definitions",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "presentation-definitions"]
						}
					}
				},
				{
					"name": "Get All Presentation Definitions",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Authorization", "value": "{{admin_auth}}"}
						],
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/presentation-definitions",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "presentation-definitions"]
						}
					}
				},
				{
					"name": "Get Presentation Definition by ID",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Authorization", "value": "{{admin_auth}}"}
						],
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/presentation-definitions/{{presentation_definition_id}}",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "presentation-definitions", "{{presentation_definition_id}}"]
						}
					}
				},
				{
					"name": "Update Presentation Definition",
					"request": {
						"method": "PUT",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "{{admin_auth}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Updated University Credential\",\n  \"purpose\": \"Updated purpose\",\n  \"definition\": {\n    \"id\": \"university-credential-def\",\n    \"name\": \"Updated University Credential Verification\",\n    \"purpose\": \"Updated purpose\",\n    \"input_descriptors\": [\n      {\n        \"id\": \"university-credential\",\n        \"name\": \"University Credential\",\n        \"format\": {\n          \"vc+sd-jwt\": {}\n        },\n        \"constraints\": {\n          \"fields\": [\n            {\n              \"path\": [\"$.vct\"],\n              \"filter\": {\n                \"type\": \"string\",\n                \"const\": \"UniversityDegreeCredential\"\n              }\n            },\n            {\n              \"path\": [\"$.email\"]\n            },\n            {\n              \"path\": [\"$.alumniOf\"]\n            }\n          ]\n        }\n      }\n    ]\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/presentation-definitions/{{presentation_definition_id}}",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "presentation-definitions", "{{presentation_definition_id}}"]
						}
					}
				},
				{
					"name": "Delete Presentation Definition",
					"request": {
						"method": "DELETE",
						"header": [
							{"key": "Authorization", "value": "{{admin_auth}}"}
						],
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/presentation-definitions/{{presentation_definition_id}}",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "presentation-definitions", "{{presentation_definition_id}}"]
						}
					}
				}
			]
		},
		{
			"name": "VP Request Flow",
			"description": "VP Request creation and status polling",
			"item": [
				{
					"name": "Create VP Request",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.requestId) {",
									"    pm.collectionVariables.set('request_id', jsonData.requestId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"clientId\": \"did:key:test-verifier\",\n  \"presentationDefinitionId\": \"{{presentation_definition_id}}\",\n  \"responseMode\": \"direct_post\",\n  \"didMethod\": \"did:key\",\n  \"signingAlgorithm\": \"EdDSA\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/vp-request",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "vp-request"]
						}
					}
				},
				{
					"name": "Get VP Request JWT",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/vp-request/{{request_id}}",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "vp-request", "{{request_id}}"]
						}
					}
				},
				{
					"name": "Fetch Request URI (Wallet)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/request-uri/{{request_id}}",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "request-uri", "{{request_id}}"]
						}
					}
				},
				{
					"name": "Poll VP Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/vp-status/{{request_id}}/status",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "vp-status", "{{request_id}}", "status"]
						}
					}
				},
				{
					"name": "Poll VP Status (Long Poll)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/vp-status/{{request_id}}/status?long_poll=true&timeout=30",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "vp-status", "{{request_id}}", "status"],
							"query": [
								{"key": "long_poll", "value": "true"},
								{"key": "timeout", "value": "30"}
							]
						}
					}
				},
				{
					"name": "Poll Wallet Status (Login Page)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/wallet-status/{{request_id}}",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "wallet-status", "{{request_id}}"]
						}
					}
				}
			]
		},
		{
			"name": "VP Submission (Wallet → Verifier)",
			"description": "Simulates wallet submitting a VP response",
			"item": [
				{
					"name": "Submit VP (direct_post - SD-JWT)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{"key": "state", "value": "{{request_id}}", "type": "text"},
								{"key": "vp_token", "value": "<PASTE_SD_JWT_VP_TOKEN_HERE>", "type": "text"},
								{"key": "presentation_submission", "value": "{\"id\":\"submission-1\",\"definition_id\":\"university-credential-def\",\"descriptor_map\":[{\"id\":\"university-credential\",\"format\":\"vc+sd-jwt\",\"path\":\"$\"}]}", "type": "text"}
							]
						},
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/response",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "response"]
						}
					}
				},
				{
					"name": "Submit VP (direct_post - JWT VP)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{"key": "state", "value": "{{request_id}}", "type": "text"},
								{"key": "vp_token", "value": "<PASTE_JWT_VP_TOKEN_HERE>", "type": "text"},
								{"key": "presentation_submission", "value": "{\"id\":\"submission-1\",\"definition_id\":\"test-def\",\"descriptor_map\":[{\"id\":\"test-credential\",\"format\":\"jwt_vp\",\"path\":\"$\"}]}", "type": "text"}
							]
						},
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/response",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "response"]
						}
					}
				},
				{
					"name": "Submit VP (Wallet Error)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{"key": "state", "value": "{{request_id}}", "type": "text"},
								{"key": "error", "value": "user_cancelled", "type": "text"},
								{"key": "error_description", "value": "User cancelled the request", "type": "text"}
							]
						},
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/response",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "response"]
						}
					}
				},
				{
					"name": "Submit VP (Missing vp_token)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{"key": "state", "value": "{{request_id}}", "type": "text"}
							]
						},
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/response",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "response"]
						}
					}
				},
				{
					"name": "Submit VP (Invalid Content Type)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\"vp_token\": \"test\"}"
						},
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/response",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "response"]
						}
					}
				}
			]
		},
		{
			"name": "VC Verification",
			"description": "Standalone VC verification endpoint",
			"item": [
				{
					"name": "Verify JWT VC",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "{{admin_auth}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"vcToken\": \"<PASTE_JWT_VC_HERE>\",\n  \"contentType\": \"application/vc+jwt\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/vc-verification",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "vc-verification"]
						}
					}
				},
				{
					"name": "Verify SD-JWT VC",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "{{admin_auth}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"vcToken\": \"<PASTE_SD_JWT_VC_HERE>\",\n  \"contentType\": \"vc+sd-jwt\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/vc-verification",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "vc-verification"]
						}
					}
				},
				{
					"name": "Verify JSON-LD VC",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "{{admin_auth}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"vcToken\": \"{\\\"@context\\\":[\\\"https://www.w3.org/2018/credentials/v1\\\"],\\\"type\\\":[\\\"VerifiableCredential\\\"],\\\"credentialSubject\\\":{\\\"id\\\":\\\"did:example:123\\\"}}\",\n  \"contentType\": \"application/vc+ld+json\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/openid4vp/v1/vc-verification",
							"host": ["{{base_url}}"],
							"path": ["openid4vp", "v1", "vc-verification"]
						}
					}
				}
			]
		},
		{
			"name": "DID Document",
			"description": "Verifier DID document endpoint",
			"item": [
				{
					"name": "Get Verifier DID Document",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/.well-known/did.json",
							"host": ["{{base_url}}"],
							"path": [".well-known", "did.json"]
						}
					}
				}
			]
		}
	]
}
