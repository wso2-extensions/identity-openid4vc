<!--
  SpotBugs / find-sec-bugs exclude filter for the authenticator component.

  UNVALIDATED_REDIRECT in initiateAuthenticationRequest:
  - find-sec-bugs flags any non-constant argument to HttpServletResponse.sendRedirect()
    regardless of runtime validation.
  - The redirect target (loginPage) is sourced exclusively from server-side configuration
    (IdentityUtil.getProperty or the hardcoded default "/authenticationendpoint/wallet_login.jsp").
    It is NOT user-supplied input.
  - SecurityUtils.isSafeRedirectUri() validates the full URL at runtime before the redirect
    is issued; any URL that fails validation causes an AuthenticationFailedException.
  - getLoginPage() additionally enforces that the configured value passes isSafeRedirectUri()
    at the point of retrieval, providing defense-in-depth.
  - This is therefore a false positive: the redirect cannot be influenced by an attacker.
-->
<FindBugsFilter>
    <Match>
        <Class name="org.wso2.carbon.identity.openid4vc.presentation.authenticator.OpenID4VPAuthenticator"/>
        <Method name="initiateAuthenticationRequest"/>
        <Bug pattern="UNVALIDATED_REDIRECT"/>
    </Match>
</FindBugsFilter>
