    ],
    "event": [
        {
            "listen": "prerequest",
            "script": {
                "type": "text/javascript",
                "exec": [
                    "// Set default values if not set",
                    "if (!pm.variables.get('request_id')) {",
                    "    pm.variables.set('request_id', 'sample-request-id');",
                    "}"
                ]
            }
        },
        {
            "listen": "test",
            "script": {
                "type": "text/javascript",
                "exec": [
                    "// Auto-extract request_id from Create VP Request response",
                    "if (pm.info.requestName === 'Create VP Request' && pm.response.code === 200) {",
                    "    var response = pm.response.json();",
                    "    if (response.requestId) {",
                    "        pm.collectionVariables.set('request_id', response.requestId);",
                    "        console.log('Set request_id: ' + response.requestId);",
                    "    }",
                    "    if (response.transactionId) {",
                    "        pm.collectionVariables.set('transaction_id', response.transactionId);",
                    "        console.log('Set transaction_id: ' + response.transactionId);",
                    "    }",
                    "}"
                ]
            }
        }
    ]
}