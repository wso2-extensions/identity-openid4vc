{
    "info": {
        "_postman_id": "openid4vp-api-collection",
        "name": "OpenID4VP API Collection",
        "description": "API collection for testing OpenID4VP endpoints in WSO2 Identity Server.\n\n**Base URL:** `https://localhost:9443`\n\n**Authentication:** Basic Auth with admin:admin for management APIs.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "https://localhost:9443",
            "type": "string"
        },
        {
            "key": "username",
            "value": "admin",
            "type": "string"
        },
        {
            "key": "password",
            "value": "admin",
            "type": "string"
        },
        {
            "key": "request_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "transaction_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "definition_id",
            "value": "default-presentation-definition",
            "type": "string"
        },
        {
            "key": "application_id",
            "value": "",
            "type": "string"
        }
    ],
    "auth": {
        "type": "basic",
        "basic": [
            {
                "key": "username",
                "value": "{{username}}",
                "type": "string"
            },
            {
                "key": "password",
                "value": "{{password}}",
                "type": "string"
            }
        ]
    },
    "item": [
        {
            "name": "DID Document",
            "item": [
                {
                    "name": "Get DID Document",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/did+json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/.well-known/did.json",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                ".well-known",
                                "did.json"
                            ]
                        },
                        "description": "Get the verifier's DID document (did:web method)."
                    },
                    "response": []
                }
            ],
            "description": "DID Document endpoints for verifier identity."
        },
        {
            "name": "VP Request",
            "item": [
                {
                    "name": "Create VP Request",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"clientId\": \"did:web:localhost%3A9443\",\n  \"presentationDefinitionId\": \"{{definition_id}}\",\n  \"responseUri\": \"{{base_url}}/openid4vp/v1/response\",\n  \"responseMode\": \"direct_post\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/openid4vp/v1/request",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "openid4vp",
                                "v1",
                                "request"
                            ]
                        },
                        "description": "Create a new VP authorization request. Returns requestId and requestUri for wallet."
                    },
                    "response": []
                },
                {
                    "name": "Get Request Object (Wallet Endpoint)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/oauth-authz-req+jwt"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/openid4vp/v1/request-uri/{{request_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "openid4vp",
                                "v1",
                                "request-uri",
                                "{{request_id}}"
                            ]
                        },
                        "description": "Wallet fetches the signed JWT authorization request object using the request_uri from the QR code."
                    },
                    "response": []
                },
                {
                    "name": "Poll VP Status",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/openid4vp/v1/status/{{request_id}}?timeout=30",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "openid4vp",
                                "v1",
                                "status",
                                "{{request_id}}"
                            ],
                            "query": [
                                {
                                    "key": "timeout",
                                    "value": "30",
                                    "description": "Long polling timeout in seconds"
                                }
                            ]
                        },
                        "description": "Poll for VP submission status. Supports long polling with timeout parameter."
                    },
                    "response": []
                },
                {
                    "name": "Get VP Result",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/openid4vp/v1/result/{{request_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "openid4vp",
                                "v1",
                                "result",
                                "{{request_id}}"
                            ]
                        },
                        "description": "Get the detailed verification result after VP submission is complete."
                    },
                    "response": []
                }
            ],
            "description": "VP Request lifecycle endpoints."
        },
        {
            "name": "VP Submission (Wallet)",
            "item": [
                {
                    "name": "Submit VP (Form Encoded)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/x-www-form-urlencoded"
                            }
                        ],
                        "body": {
                            "mode": "urlencoded",
                            "urlencoded": [
                                {
                                    "key": "vp_token",
                                    "value": "eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCIsImtpZCI6ImRpZDprZXk6ejZNa2hhWC4uLiJ9.eyJpc3MiOiJkaWQ6a2V5Ono2TWtoYVguLi4iLCJ2cCI6eyJAY29udGV4dCI6WyJodHRwczovL3d3dy53My5vcmcvMjAxOC9jcmVkZW50aWFscy92MSJdLCJ0eXBlIjpbIlZlcmlmaWFibGVQcmVzZW50YXRpb24iXSwidmVyaWZpYWJsZUNyZWRlbnRpYWwiOltdfX0.SIGNATURE",
                                    "description": "JWT-encoded Verifiable Presentation",
                                    "type": "text"
                                },
                                {
                                    "key": "presentation_submission",
                                    "value": "{\"id\":\"submission-1\",\"definition_id\":\"default-presentation-definition\",\"descriptor_map\":[{\"id\":\"vc-1\",\"format\":\"jwt_vc_json\",\"path\":\"$.verifiableCredential[0]\"}]}",
                                    "description": "DIF Presentation Submission JSON",
                                    "type": "text"
                                },
                                {
                                    "key": "state",
                                    "value": "{{request_id}}",
                                    "description": "Request ID (correlation)",
                                    "type": "text"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/openid4vp/v1/response",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "openid4vp",
                                "v1",
                                "response"
                            ]
                        },
                        "description": "Wallet submits VP using form-encoded body (direct_post response mode)."
                    },
                    "response": []
                },
                {
                    "name": "Submit VP (JSON)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"vp_token\": \"eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9...\",\n  \"presentation_submission\": {\n    \"id\": \"submission-1\",\n    \"definition_id\": \"default-presentation-definition\",\n    \"descriptor_map\": [\n      {\n        \"id\": \"vc-1\",\n        \"format\": \"jwt_vc_json\",\n        \"path\": \"$.verifiableCredential[0]\"\n      }\n    ]\n  },\n  \"state\": \"{{request_id}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/openid4vp/v1/response",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "openid4vp",
                                "v1",
                                "response"
                            ]
                        },
                        "description": "Wallet submits VP using JSON body."
                    },
                    "response": []
                },
                {
                    "name": "Submit VP Error",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/x-www-form-urlencoded"
                            }
                        ],
                        "body": {
                            "mode": "urlencoded",
                            "urlencoded": [
                                {
                                    "key": "error",
                                    "value": "access_denied",
                                    "description": "Error code",
                                    "type": "text"
                                },
                                {
                                    "key": "error_description",
                                    "value": "User declined to share credentials",
                                    "description": "Human-readable error description",
                                    "type": "text"
                                },
                                {
                                    "key": "state",
                                    "value": "{{request_id}}",
                                    "type": "text"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/openid4vp/v1/response",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "openid4vp",
                                "v1",
                                "response"
                            ]
                        },
                        "description": "Wallet returns an error (user declined or other failure)."
                    },
                    "response": []
                }
            ],
            "description": "Wallet-facing VP submission endpoints. These do NOT require authentication."
        },
        {
            "name": "Presentation Definitions",
            "item": [
                {
                    "name": "List All Definitions",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/openid4vp/v1/presentation-definitions",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "openid4vp",
                                "v1",
                                "presentation-definitions"
                            ]
                        },
                        "description": "List all presentation definitions for the tenant."
                    },
                    "response": []
                },
                {
                    "name": "Get Definition by ID",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/openid4vp/v1/presentation-definitions/{{definition_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "openid4vp",
                                "v1",
                                "presentation-definitions",
                                "{{definition_id}}"
                            ]
                        },
                        "description": "Get a specific presentation definition by ID."
                    },
                    "response": []
                },
                {
                    "name": "Create Presentation Definition",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"id\": \"employment-verification\",\n  \"name\": \"Employment Verification\",\n  \"description\": \"Request employment credentials\",\n  \"definitionJson\": {\n    \"id\": \"employment-verification\",\n    \"input_descriptors\": [\n      {\n        \"id\": \"employment-vc\",\n        \"name\": \"Employment Credential\",\n        \"purpose\": \"Verify current employment\",\n        \"constraints\": {\n          \"fields\": [\n            {\n              \"path\": [\"$.type\"],\n              \"filter\": {\n                \"type\": \"array\",\n                \"contains\": {\n                  \"const\": \"EmploymentCredential\"\n                }\n              }\n            }\n          ]\n        }\n      }\n    ]\n  },\n  \"isDefault\": false\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/openid4vp/v1/presentation-definitions",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "openid4vp",
                                "v1",
                                "presentation-definitions"
                            ]
                        },
                        "description": "Create a new presentation definition."
                    },
                    "response": []
                },
                {
                    "name": "Update Presentation Definition",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Employment Verification (Updated)\",\n  \"description\": \"Updated description\",\n  \"definitionJson\": {\n    \"id\": \"employment-verification\",\n    \"input_descriptors\": [\n      {\n        \"id\": \"employment-vc\",\n        \"name\": \"Employment Credential\",\n        \"purpose\": \"Verify current employment status\",\n        \"constraints\": {\n          \"fields\": [\n            {\n              \"path\": [\"$.type\"],\n              \"filter\": {\n                \"type\": \"array\",\n                \"contains\": {\n                  \"const\": \"EmploymentCredential\"\n                }\n              }\n            },\n            {\n              \"path\": [\"$.credentialSubject.employerName\"],\n              \"filter\": {\n                \"type\": \"string\"\n              }\n            }\n          ]\n        }\n      }\n    ]\n  },\n  \"isDefault\": false\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/openid4vp/v1/presentation-definitions/{{definition_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "openid4vp",
                                "v1",
                                "presentation-definitions",
                                "{{definition_id}}"
                            ]
                        },
                        "description": "Update an existing presentation definition."
                    },
                    "response": []
                },
                {
                    "name": "Delete Presentation Definition",
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/openid4vp/v1/presentation-definitions/{{definition_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "openid4vp",
                                "v1",
                                "presentation-definitions",
                                "{{definition_id}}"
                            ]
                        },
                        "description": "Delete a presentation definition."
                    },
                    "response": []
                }
            ],
            "description": "Presentation Definition management endpoints."
        },
