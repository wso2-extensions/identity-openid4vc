<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Suppress CRLF injection warnings for debug/trace logging -->
    <!-- These are low-priority and debug logs are typically not user-facing -->
    <Match>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
        <Priority value="3"/> <!-- Low priority only -->
    </Match>
    
    <!-- Suppress MS_EXPOSE_REP for singleton getInstance() methods -->
    <!-- This is by design for singleton pattern -->
    <Match>
        <Bug pattern="MS_EXPOSE_REP"/>
        <Method name="getInstance"/>
    </Match>
    
    <!-- Suppress SERVLET_PARAMETER warnings -->
    <!-- These are standard servlet request parameters that are validated -->
    <Match>
        <Bug pattern="SERVLET_PARAMETER"/>
    </Match>
    
    <!-- Suppress style warnings for case conversion in specific contexts -->
    <Match>
        <Bug pattern="DM_CONVERT_CASE"/>
        <Priority value="3"/>
    </Match>
    
    <!-- Suppress REC_CATCH_EXCEPTION when catching Exception is intentional -->
    <Match>
        <Bug pattern="REC_CATCH_EXCEPTION"/>
        <Priority value="3"/>
    </Match>
</FindBugsFilter>
