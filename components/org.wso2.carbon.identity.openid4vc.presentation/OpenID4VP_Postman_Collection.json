{
	"info": {
		"_postman_id": "openid4vp-collection-2026",
		"name": "OpenID4VP - WSO2 Identity Server",
		"description": "Complete Postman collection for testing OpenID for Verifiable Presentations (OpenID4VP) endpoints in WSO2 Identity Server.\n\nThis collection covers:\n- VP Request Creation\n- VP Submission (Wallet Response)\n- Status Polling\n- Result Retrieval\n- Presentation Definition Management",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. VP Request Management",
			"item": [
				{
					"name": "Create VP Request",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200 || pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"requestId\", jsonData.requestId);",
									"    pm.environment.set(\"transactionId\", jsonData.transactionId);",
									"    pm.environment.set(\"requestUri\", jsonData.requestUri);",
									"    console.log(\"Request ID: \" + jsonData.requestId);",
									"    console.log(\"Transaction ID: \" + jsonData.transactionId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"clientId\": \"https://localhost:9443/oauth2/token\",\n  \"responseMode\": \"direct_post\",\n  \"presentationDefinition\": {\n    \"id\": \"default-wallet-auth\",\n    \"name\": \"Wallet Authentication\",\n    \"purpose\": \"Authenticate using your digital wallet\",\n    \"input_descriptors\": [\n      {\n        \"id\": \"any-credential\",\n        \"name\": \"Any Verifiable Credential\",\n        \"purpose\": \"Present any verifiable credential from your wallet\",\n        \"constraints\": {\n          \"fields\": [\n            {\n              \"path\": [\n                \"$.type\",\n                \"$.vc.type\",\n                \"$.vct\"\n              ]\n            }\n          ]\n        }\n      }\n    ]\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/vp-request",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"vp-request"
							]
						},
						"description": "Create a new VP authorization request. This generates a request that can be presented to a wallet via QR code or deep link."
					},
					"response": []
				},
				{
					"name": "Get Request JWT (by Request ID)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/vp-request/{{requestId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"vp-request",
								"{{requestId}}"
							]
						},
						"description": "Retrieve the request JWT for a given request ID. This is used in the request_uri flow."
					},
					"response": []
				},
				{
					"name": "Get Request Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/vp-request/{{requestId}}/status",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"vp-request",
								"{{requestId}}",
								"status"
							]
						},
						"description": "Check the status of a VP request (ACTIVE, VP_SUBMITTED, COMPLETED, EXPIRED, CANCELLED)."
					},
					"response": []
				},
				{
					"name": "Poll Request Status (Long Polling)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/vp-request/{{requestId}}/status?timeout=30",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"vp-request",
								"{{requestId}}",
								"status"
							],
							"query": [
								{
									"key": "timeout",
									"value": "30",
									"description": "Timeout in seconds for long polling"
								}
							]
						},
						"description": "Long polling endpoint that waits for status changes. Useful for real-time status updates."
					},
					"response": []
				}
			],
			"description": "Endpoints for creating and managing VP authorization requests."
		},
		{
			"name": "2. VP Submission (Wallet Response)",
			"item": [
				{
					"name": "Submit VP Token (Form Encoded)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"submissionId\", jsonData.submission_id);",
									"    console.log(\"Submission ID: \" + jsonData.submission_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "vp_token",
									"value": "eyJhbGciOiJFUzI1NiIsInR5cCI6IkpXVCJ9..signature",
									"type": "text",
									"description": "JWT VP Token"
								},
								{
									"key": "presentation_submission",
									"value": "{\"id\":\"submission-1\",\"definition_id\":\"default-wallet-auth\",\"descriptor_map\":[{\"id\":\"any-credential\",\"format\":\"jwt_vp\",\"path\":\"$\"}]}",
									"type": "text",
									"description": "Presentation Submission JSON"
								},
								{
									"key": "state",
									"value": "{{requestId}}",
									"type": "text",
									"description": "Request ID (correlation)"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/response",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"response"
							]
						},
						"description": "Submit a VP token from the wallet using form-encoded format (per OpenID4VP spec)."
					},
					"response": []
				},
				{
					"name": "Submit VP Token (JSON)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"vp_token\": \"eyJhbGciOiJFUzI1NiIsInR5cCI6IkpXVCJ9..signature\",\n  \"presentation_submission\": {\n    \"id\": \"submission-1\",\n    \"definition_id\": \"default-wallet-auth\",\n    \"descriptor_map\": [\n      {\n        \"id\": \"any-credential\",\n        \"format\": \"jwt_vp\",\n        \"path\": \"$\"\n      }\n    ]\n  },\n  \"state\": \"{{requestId}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/response",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"response"
							]
						},
						"description": "Submit a VP token using JSON format (alternative to form-encoded)."
					},
					"response": []
				},
				{
					"name": "Submit VP Error (User Cancelled)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "error",
									"value": "user_cancelled",
									"type": "text"
								},
								{
									"key": "error_description",
									"value": "User cancelled the authentication request",
									"type": "text"
								},
								{
									"key": "state",
									"value": "{{requestId}}",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/response",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"response"
							]
						},
						"description": "Submit an error response when the user cancels or the wallet encounters an error."
					},
					"response": []
				}
			],
			"description": "Endpoints for wallet VP submission (direct_post response mode)."
		},
		{
			"name": "3. VP Result Retrieval",
			"item": [
				{
					"name": "Get VP Result (Full)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/vp-result/{{transactionId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"vp-result",
								"{{transactionId}}"
							]
						},
						"description": "Retrieve the full verification results for a submitted VP using the transaction ID."
					},
					"response": []
				},
				{
					"name": "Get VP Result Summary",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/vp-result/{{transactionId}}/summary",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"vp-result",
								"{{transactionId}}",
								"summary"
							]
						},
						"description": "Retrieve a summary of the verification results (success/failure status only)."
					},
					"response": []
				}
			],
			"description": "Endpoints for retrieving VP verification results."
		},
		{
			"name": "4. Presentation Definitions",
			"item": [
				{
					"name": "Get All Presentation Definitions",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/presentation-definitions",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"presentation-definitions"
							]
						},
						"description": "List all available presentation definitions."
					},
					"response": []
				},
				{
					"name": "Get Presentation Definition by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/presentation-definitions/{{definitionId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"presentation-definitions",
								"{{definitionId}}"
							]
						},
						"description": "Retrieve a specific presentation definition by its ID."
					},
					"response": []
				},
				{
					"name": "Create Presentation Definition",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"employee-credential\",\n  \"name\": \"Employee Credential\",\n  \"purpose\": \"Verify employee status\",\n  \"input_descriptors\": [\n    {\n      \"id\": \"employee-vc\",\n      \"name\": \"Employee Verifiable Credential\",\n      \"purpose\": \"Verify that you are an employee\",\n      \"constraints\": {\n        \"fields\": [\n          {\n            \"path\": [\"$.type\"],\n            \"filter\": {\n              \"type\": \"array\",\n              \"contains\": {\n                \"const\": \"EmployeeCredential\"\n              }\n            }\n          },\n          {\n            \"path\": [\"$.credentialSubject.employeeId\"]\n          }\n        ]\n      }\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/presentation-definitions",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"presentation-definitions"
							]
						},
						"description": "Create a new presentation definition."
					},
					"response": []
				}
			],
			"description": "Endpoints for managing presentation definitions."
		},
		{
			"name": "5. Complete Flow Test",
			"item": [
				{
					"name": "Step 1: Create VP Request",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 or 201\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"});",
									"",
									"pm.test(\"Response has required fields\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('requestId');",
									"    pm.expect(jsonData).to.have.property('transactionId');",
									"    pm.expect(jsonData).to.have.property('requestUri');",
									"});",
									"",
									"if (pm.response.code === 200 || pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"flow_requestId\", jsonData.requestId);",
									"    pm.environment.set(\"flow_transactionId\", jsonData.transactionId);",
									"    console.log(\"✓ VP Request Created\");",
									"    console.log(\"  Request ID: \" + jsonData.requestId);",
									"    console.log(\"  Transaction ID: \" + jsonData.transactionId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"clientId\": \"https://localhost:9443/oauth2/token\",\n  \"responseMode\": \"direct_post\",\n  \"presentationDefinition\": {\n    \"id\": \"test-flow-auth\",\n    \"name\": \"Test Flow Authentication\",\n    \"purpose\": \"Complete flow test\",\n    \"input_descriptors\": [\n      {\n        \"id\": \"any-credential\",\n        \"name\": \"Any Verifiable Credential\",\n        \"constraints\": {\n          \"fields\": [\n            {\n              \"path\": [\"$.type\", \"$.vc.type\", \"$.vct\"]\n            }\n          ]\n        }\n      }\n    ]\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/vp-request",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"vp-request"
							]
						}
					},
					"response": []
				},
				{
					"name": "Step 2: Check Initial Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status is ACTIVE\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.eql(\"ACTIVE\");",
									"});",
									"console.log(\"✓ Status checked: ACTIVE\");"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/vp-request/{{flow_requestId}}/status",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"vp-request",
								"{{flow_requestId}}",
								"status"
							]
						}
					},
					"response": []
				},
				{
					"name": "Step 3: Submit VP Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Submission successful\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"console.log(\"✓ VP Token submitted\");"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "vp_token",
									"value": "eyJhbGciOiJFUzI1NiIsInR5cCI6IkpXVCJ9..signature",
									"type": "text"
								},
								{
									"key": "presentation_submission",
									"value": "{\"id\":\"test-submission\",\"definition_id\":\"test-flow-auth\",\"descriptor_map\":[{\"id\":\"any-credential\",\"format\":\"jwt_vp\",\"path\":\"$\"}]}",
									"type": "text"
								},
								{
									"key": "state",
									"value": "{{flow_requestId}}",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/response",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"response"
							]
						}
					},
					"response": []
				},
				{
					"name": "Step 4: Get Verification Result",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Result retrieved\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"console.log(\"✓ Verification result retrieved\");"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/openid4vp/v1/vp-result/{{flow_transactionId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"openid4vp",
								"v1",
								"vp-result",
								"{{flow_transactionId}}"
							]
						}
					},
					"response": []
				}
			],
			"description": "Complete end-to-end flow test with automated assertions."
		}
	],
